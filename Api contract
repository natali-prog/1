{
  "openapi": "3.0.3",
  "info": {
    "title": "Courses Microservice API",
    "description": "ДЗ по платформе курсов",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.платформакурса.com/v1",
      "description": "Описание платформы курсов"
    },
    {
      "url": "http://localhost:8080/api/v1",
      "description": "Хост"
    }
  ],
  "tags": [
    {
      "name": "courses",
      "description": "Основные операции с курсами"
    },
    {
      "name": "registration",
      "description": "Управление регистрацией на курсы"
    }
  ],
  "paths": {
    "/courses": {
      "get": {
        "tags": [
          "courses"
        ],
        "summary": "Получить список курсов из каталога",
        "description": "Возвращает список всех курсов",
        "operationId": "getCourses",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "description": "Фильтр по статусу курса",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "Draft",
                "Published",
                "Archived"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Успешный ответ со списком курсов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Course"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "courses"
        ],
        "summary": "Создать новый курс",
        "description": "Создает новую запись курса в БД",
        "operationId": "createCourse",
        "requestBody": {
          "description": "Данные нового курса",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CourseInput"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Уникальный идентификатор запроса (UUID) для обеспечения идемпотентности при повторных отправках.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "7b9e4567-e89b-12d3-a456-426614174000"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Курс успешно создан",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные входные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/courses/{courseId}": {
      "parameters": [
        {
          "name": "courseId",
          "in": "path",
          "description": "Уникальный идентификатор курса",
          "required": true,
          "schema": {
            "type": "string",
            "format": "uuid"
          }
        }
      ],
      "get": {
        "tags": [
          "courses"
        ],
        "summary": "Получить курс по ID",
        "description": "Возвращает инфо о конкретном курсе",
        "operationId": "getCourseById",
        "responses": {
          "200": {
            "description": "Успешный ответ",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "404": {
            "description": "Курс не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "courses"
        ],
        "summary": "Обновить данные курса",
        "description": "Полностью обновляет инфо о конкретном курсе.",
        "operationId": "updateCourse",
        "requestBody": {
          "description": "Обновленные данные курса",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CourseInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Курс успешно обновлен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Course"
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Курс не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "courses"
        ],
        "summary": "Удалить курс",
        "description": "Помечает курс как удаленный",
        "operationId": "deleteCourse",
        "responses": {
          "204": {
            "description": "Курс успешно удален"
          },
          "404": {
            "description": "Курс не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/courses/{courseId}/register": {
      "post": {
        "tags": [
          "registration"
        ],
        "summary": "Регистрация на курс (запись на курс)",
        "description": "Получение доступа к курсу",
        "operationId": "registerForCourse",
        "parameters": [
          {
            "name": "courseId",
            "in": "path",
            "description": "UUID курса, на который запрашивается регистрация",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Уникальный идентификатор запроса (UUID) для обеспечения идемпотентности при повторных отправках.",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "example": "7b9e4567-e89b-12d3-a456-426614174000"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Регистрация успешно завершена",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Registration"
                }
              }
            }
          },
          "403": {
            "description": "Доступ запрещен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Курс не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Данные устарели. Повторите запрос",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "501": {
            "description": "Ошибка сервера",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Course": {
        "type": "object",
        "description": "Тип курса",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "example": "123e4567-e89b-12d3-a456-426614174000"
          },
          "autorId": {
            "type": "string",
            "format": "uuid",
            "description": "Внешний ключ автора"
          },
          "title": {
            "type": "string",
            "example": "Курс системного аналитика"
          },
          "description": {
            "type": "string",
            "example": "Курс системного аналитика"
          },
          "price": {
            "type": "number",
            "format": "float",
            "example": 19.99
          },
          "status": {
            "type": "string",
            "enum": [
              "Draft",
              "Published",
              "Archived"
            ],
            "example": "Published"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CourseInput": {
        "type": "object",
        "description": "Создание и обновление курса",
        "required": [
          "title",
          "status",
          "autorId"
        ],
        "properties": {
          "autorId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string",
            "example": "Курс системного аналитика"
          },
          "description": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "format": "float"
          },
          "status": {
            "type": "string",
            "enum": [
              "Draft",
              "Published",
              "Archived"
            ]
          }
        }
      },
      "Registration": {
        "type": "object",
        "description": "Данные о регистрации студента на курс",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "studentId": {
            "type": "string",
            "format": "uuid"
          },
          "courseId": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "enum": [
              "Active",
              "Completed",
              "Cancelled"
            ],
            "example": "Active"
          },
          "registeredAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "example": 400
          },
          "message": {
            "type": "string",
            "example": "Invalid input provided"
          }
        }
      }
    }
  }
}
